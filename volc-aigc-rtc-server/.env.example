PORT=8788
VOLCENGINE_ACCESS_KEY=
VOLCENGINE_SECRET_KEY=
VOLCENGINE_SESSION_TOKEN=

VOLC_KNOWLEDGE_API_STYLE=search_knowledge
VOLC_KNOWLEDGE_HOST=api-knowledgebase.mlp.cn-beijing.volces.com
VOLC_KNOWLEDGE_REGION=cn-north-1
VOLC_KNOWLEDGE_SERVICE=air
VOLC_KNOWLEDGE_SEARCH_PATH=/api/knowledge/collection/search_knowledge
VOLC_KNOWLEDGE_ACCOUNT_ID=
VOLC_KNOWLEDGE_PROJECT=default
VOLC_KNOWLEDGE_RESOURCE_ID=
VOLC_KNOWLEDGE_NAME=
VOLC_KNOWLEDGE_SERVICE_RESOURCE_ID=
VOLC_KNOWLEDGE_API_KEY=
VOLC_KNOWLEDGE_LIMIT=5
VOLC_KNOWLEDGE_ACCESS_KEY=
VOLC_KNOWLEDGE_SECRET_KEY=
VOLC_KNOWLEDGE_SESSION_TOKEN=

# 方舟对话（意图识别 + ttsSummary 生成）
ARK_HOST=ark.cn-beijing.volces.com
ARK_CHAT_PATH=/api/v3/chat/Completions
ARK_CHAT_MODEL=
ARK_API_KEY=
# 方舟图片生成
ARK_IMAGE_GENERATION_PATH=/api/v3/images/generations
ARK_IMAGE_MODEL=
ARK_IMAGE_SIZE=2K
ARK_IMAGE_SEQUENTIAL_GENERATION=disabled
ARK_IMAGE_RESPONSE_FORMAT=url
ARK_IMAGE_WATERMARK=1

# 抖音视频检索
DOUYIN_VIDEO_SEARCH_HOST=cn.bing.com
DOUYIN_VIDEO_SEARCH_PATH=/search

# 火山语音合成 2.0
VOLC_TTS_HOST=openspeech.bytedance.com
VOLC_TTS_PATH=/api/v3/tts/unidirectional
VOLC_TTS_APP_ID=
VOLC_TTS_ACCESS_TOKEN=
VOLC_TTS_SECRET_KEY=
VOLC_TTS_RESOURCE_ID=seed-tts-2.0
VOLC_TTS_SPEAKER=zh_female_qingxinnvsheng_uranus_bigtts
VOLC_TTS_SAMPLE_RATE=24000
VOLC_TTS_BIT_RATE=64000

# memory module backend mode: mock | viking
MEMORY_BACKEND_MODE=mock
VOLC_MEMORY_LIMIT=10

# --- [Viking 记忆库配置] ---
VIKING_MEMORY_API_KEY=
VIKING_MEMORY_RESOURCE_ID=
VIKING_MEMORY_COLLECTION_NAME=
VIKING_MEMORY_API_SERVICE_NAME=
VIKING_MEMORY_HOST=api-knowledgebase.mlp.cn-beijing.volces.com
VIKING_MEMORY_EVENT_TYPE=event_v1
VIKING_MEMORY_PROFILE_TYPE=profile_v1
SESSION_RECORD_FILE=./data/session-records.json

# AI 音视频互动方案 AppId，且需与生成 RTC 鉴权 Token 时使用的 AppId 一致
VOLC_RTC_APP_ID=
VOLC_RTC_APP_KEY=

VOLC_RTC_OPENAPI_HOST=rtc.volcengineapi.com
VOLC_RTC_OPENAPI_REGION=cn-north-1
VOLC_RTC_OPENAPI_VERSION=2025-06-01

# 默认智能体信息，可在请求体里覆盖
DEFAULT_AGENT_USER_ID=ai_bot_001
DEFAULT_WELCOME_MESSAGE=你好，我是你的游戏 AI 助手。

# 用于服务端接收字幕/状态回调，可选
DEFAULT_RTS_CALLBACK_URL=
DEFAULT_RTS_CALLBACK_SIGNATURE=

# RTC 记忆与玩家画像配置
RTC_PERSONA_PROFILE_DIR=./data/rtc-persona-profiles
RTC_SESSION_STATE_FILE=./data/rtc-session-state.json
# HistoryLength 按"轮"计，5 表示大约保留最近 10 句一问一答
RTC_SHORT_HISTORY_LENGTH=5
RTC_SHORT_PROMPT_MESSAGE_LIMIT=10
# 开启 Function Calling 后，RTC 服务端回调用于自动更新 persona 档案
RTC_FUNCTION_CALLBACK_URL=
RTC_FUNCTION_CALLBACK_SIGNATURE=
RTC_ENABLE_PERSONA_FUNCTION_TOOL=1

# 你提供官方 RTC Token JS 生成器后，把路径指到该文件
RTC_TOKEN_GENERATOR_PATH=./vendor/rtc-token-generator.js

# --- [RTC CustomLLM 桥接配置] ---
# 填写后，StartVoiceChat 自动使用 CustomLLM 模式（Agent 编排为主，RTC 仅做语音管道）
# 留空则保持原有 ArkV3 模式（向后兼容）
# 本地开发：先启动 localtunnel（npx localtunnel --port 8788），把生成的 URL 填入
# 生产部署：填公网服务器地址即可，如 https://your-server.com
CUSTOM_LLM_BASE_URL=
CUSTOM_LLM_API_KEY=
